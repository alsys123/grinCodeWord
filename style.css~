  
    body {
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      display: flex;
      justify-content: center;
      align-items: flex-start;
      min-height: 100vh;
      background: #f7f4ef; /* Warm background */
      padding: 20px;
    }

    .wrapper {
      background: #fffdf7; /* Soft cream */
      padding: 20px;
      border-radius: 12px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.08);
      width: 620px;
    }

    #alert {
      display: none;
      background: #d00000;
      color: white;
      padding: 10px;
      text-align: center;
      font-weight: bold;
      border-radius: 6px;
      margin-bottom: 10px;
    }

    h1 {
      font-size: 20px;
      margin: 0 0 12px;
      text-align: center;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(13, 40px);
      grid-auto-rows: 40px;
      gap: 3px;
      margin-bottom: 16px;
    }

    .cell {
      position: relative;
      width: 40px;
      height: 40px;
      border: 1px solid #c8c3b8;
      background: #fffdf7; /* Soft cream */
      overflow: hidden;
      touch-action: manipulation;
    }

    .cell.black {
      background: #1c1c1c; /* Softer black */
      border-color: #1c1c1c;
      pointer-events: none;
    }

    .number-label {
      position: absolute;
      top: 2px;
      left: 3px;
      font-size: 9px;
      color: #444;
      pointer-events: none;
    user-select: none;
      z-index: 3; /* <-- add this */
    }

    canvas {
      width: 100%;
      height: 100%;
      touch-action: none;
      cursor: crosshair;
    }

    .letter {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 22px;
      font-weight: 600;
      font-family: "Georgia", "Times New Roman", serif;
      color: #111;
      background: #fffdf7;
      user-select: none;
    }

    .letter.starter {
      color: #b00020;
    }

    .letter.wrong {
      color: red;
    }

    .hint {
      margin-top: 10px;
      font-size: 13px;
      text-align: center;
      font-weight: 500;
    }

    .key-grid {
      margin-top: 14px;
      display: grid;
      grid-template-columns: repeat(13, 40px);
      grid-auto-rows: 40px;
      gap: 3px;
    }

    #checkBtn {
      margin-top: 15px;
      width: 100%;
      padding: 10px;
      background: #0077cc;
      color: white;
      border: none;
      border-radius: 6px;
      font-size: 15px;
      cursor: pointer;
      font-weight: 600;
    }

    #checkBtn:hover {
      background: #005fa3;
    }

    .status {
      margin-top: 6px;
      font-size: 12px;
      color: #666;
      text-align: center;
    }
 
